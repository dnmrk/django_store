# Copy to /etc/django-store/django-store.env on the server and keep it out of git.
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=django.henshuuz.dev,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://django.henshuuz.dev
CORS_ALLOWED_ORIGINS=https://django.henshuuz.dev
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=False
DB_NAME=/var/lib/django-store/db.sqlite3
STATIC_ROOT=/var/www/django-store/static
MEDIA_ROOT=/var/www/django-store/media
