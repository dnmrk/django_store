# Copy to /etc/django-store/django-store.env on the server and keep it out of git.
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=django.henshuuz.dev
CSRF_TRUSTED_ORIGINS=https://django.henshuuz.dev
CORS_ALLOWED_ORIGINS=https://django.henshuuz.dev
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
# Set to True once TLS is provisioned (see "TLS" in deploy/README.md).
# Leaving it True without a certificate causes a redirect loop to a dead port.
SECURE_SSL_REDIRECT=True
DB_NAME=/var/lib/django-store/db.sqlite3
STATIC_ROOT=/var/www/django-store/static
MEDIA_ROOT=/var/www/django-store/media
